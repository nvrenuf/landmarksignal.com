---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
---
<BaseLayout title="LandmarkSignal Audit" description="Evidence trails for AI governance, compliance, and assurance.">
  <SiteHeader />
  <main>
    <section class="hero product-hero">
      <div class="container hero-copy">
        <p class="hero-kicker">Early Product Page</p>
        <h1>Evidence trails for AI governance, compliance, and assurance.</h1>
        <p class="hero-body">Audit records what happened, why it happened, who approved it, what tools were touched, and what evidence supports the decision.</p>
        <p class="hero-body">This is an early product page and will be expanded with assurance workflows and reporting pathways.</p>
        <div class="hero-actions">
          <a class="button button-primary" href="/runtime">Explore Runtime</a>
          <a class="button button-secondary" href="mailto:briefings@landmarksignal.com?subject=LandmarkSignal%20Platform%20Briefing">Request a briefing</a>
        </div>
      </div>
    </section>
  </main>
  <SiteFooter />
</BaseLayout>
