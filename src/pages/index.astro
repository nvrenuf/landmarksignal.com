---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
---

<BaseLayout title="LandmarkSignal | Intelligence you can trust" description="LandmarkSignal helps security and governance teams see, control, and prove enterprise AI activity.">
  <SiteHeader />

  <main>
    <section class="hero hero-home hero-light">
      <div class="container hero-layout">
        <div class="hero-copy">
          <h1>Intelligence you can trust. Decisions you can defend.</h1>
          <p class="hero-body">LandmarkSignal helps security and governance teams see, control, and prove enterprise AI activity across models, agents, tools, and workflows.</p>
          <div class="hero-actions">
            <a class="button button-primary" href="mailto:briefings@landmarksignal.com?subject=LandmarkSignal%20Briefing">Request a Briefing</a>
            <a class="button button-secondary" href="/runtime">Explore Runtime</a>
          </div>
        </div>
        <aside class="hero-abstract" aria-label="LandmarkSignal platform overview visual">
          <div class="abstract-node">Identity & Tenant Scope</div>
          <div class="abstract-node">Policy & Tool Controls</div>
          <div class="abstract-node">Model Routing</div>
          <div class="abstract-node">Evidence Trace</div>
        </aside>
      </div>
    </section>

    <section class="section trust-chips-section">
      <div class="container trust-chip-grid">
        <article class="trust-chip"><h3>Governed by Design</h3><p>Controls are designed into AI workflows from request to response.</p></article>
        <article class="trust-chip"><h3>AI Activity Visibility</h3><p>Teams can see operational signals across models, agents, and tools.</p></article>
        <article class="trust-chip"><h3>Evidence You Can Defend</h3><p>Traceable records are built to support enterprise review and assurance.</p></article>
      </div>
    </section>

    <section class="section" id="products">
      <div class="container">
        <div class="section-intro section-intro-centered">
          <h2>Secure AI operations without blind spots.</h2>
          <p>LandmarkSignal Runtime is the enterprise AI control plane designed to give security teams visibility, policy enforcement, and audit evidence across AI workflows.</p>
        </div>
        <div class="offering-grid offering-grid-3">
          <article class="offering-card">
            <p class="product-label">Visibility / intelligence</p>
            <h3>LandmarkSignal Radar</h3>
            <p>Sees AI activity and operational signals so security teams can understand what is happening across models, agents, and workflows.</p>
          </article>
          <article class="offering-card">
            <p class="product-label">Enforcement / controls</p>
            <h3>LandmarkSignal Shield</h3>
            <p>Controls policy, tool use, model routing, and data access so approved actions can proceed and risky actions can be constrained.</p>
          </article>
          <article class="offering-card">
            <p class="product-label">Evidence / traceability</p>
            <h3>LandmarkSignal Audit</h3>
            <p>Proves what happened with traceable evidence designed to support enterprise security, governance, and compliance reviews.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="section mission-section">
      <div class="container mission-panel">
        <div>
          <h2>Built for high-trust AI operations.</h2>
          <p>LandmarkSignal is focused on helping organizations adopt AI without losing visibility, control, or evidence.</p>
        </div>
        <a class="button button-secondary" href="/runtime">Explore Runtime</a>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="section-intro section-intro-centered">
          <h2>Resources</h2>
          <p>Focused publishing areas are coming soon.</p>
        </div>
        <div class="resource-grid">
          <article class="resource-card"><h3>Runtime Briefings</h3><p>Briefings and product overviews coming soon.</p></article>
          <article class="resource-card"><h3>AI Control Plane Notes</h3><p>Implementation notes and guidance coming soon.</p></article>
          <article class="resource-card"><h3>Security Architecture Updates</h3><p>Architecture updates and release notes coming soon.</p></article>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>
