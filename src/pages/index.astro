---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";

const controls = [
  ["Model calls", "Route approved model access through Runtime policy checks."],
  ["Tool calls", "Permit, deny, and record tool invocation before execution."],
  ["Agent actions", "Track delegated steps across agents, users, and workflows."],
  ["Retrieval and data access", "Control which sources AI systems can query or expose."],
  ["Policy decisions", "Record the verdict, reason, and control path for review."]
];

const products = [
  ["LandmarkSignal Radar", "Visibility", "Visibility into AI activity and operational signals."],
  ["LandmarkSignal Shield", "Enforcement", "Enforcement for prompts, tools, data access, and model routing."],
  ["LandmarkSignal Audit", "Evidence", "Evidence trail for investigations, regulators, and boards."]
];

const threats = [
  "Prompt injection",
  "Data exfiltration",
  "Tool misuse",
  "Shadow AI visibility gaps",
  "Unauthorized model routing",
  "Missing audit evidence"
];

const deployment = [
  ["Local", "Run close to controlled systems and sensitive workflows."],
  ["Private cloud", "Deploy inside organization-managed cloud boundaries."],
  ["Hybrid", "Bridge local controls with approved external AI services."],
  ["Self-hosted-first", "Designed for buyers who need direct operational control."]
];
---

<BaseLayout
  title="LandmarkSignal Runtime"
  description="LandmarkSignal Runtime is the control plane for enterprise AI, giving security teams visibility, policy enforcement, and audit evidence across models, agents, tools, and AI workflows."
>
  <SiteHeader />

  <main id="top">
    <section class="hero">
      <div class="container hero-layout">
        <div class="hero-copy">
          <img class="hero-logo" src="/brand/landmarksignal-logo-light.svg" alt="LandmarkSignal" />
          <p class="hero-kicker">Runtime control plane for enterprise AI</p>
          <h1>See every AI action. Control every tool call. Prove every decision.</h1>
          <p class="hero-body">
            LandmarkSignal Runtime is the control plane for enterprise AI - giving
            security teams visibility, policy enforcement, and audit evidence across
            models, agents, tools, and AI workflows.
          </p>
          <div class="hero-actions">
            <a class="button button-primary" href="#briefing">Request a briefing</a>
            <a class="button button-secondary" href="#architecture">View technical overview</a>
          </div>
        </div>

        <aside class="runtime-panel" aria-label="AI request event example">
          <div class="panel-topline">
            <img src="/brand/landmarksignal-icon-light.svg" alt="" aria-hidden="true" />
            <div>
              <p>Runtime event</p>
              <span>AI request trace</span>
            </div>
          </div>
          <div class="event-flow" aria-label="Request path">
            <span>User</span>
            <span>Agent</span>
            <span>Model</span>
            <span>Tool</span>
          </div>
          <dl class="event-details">
            <div>
              <dt>User</dt>
              <dd>security-analyst@example.com</dd>
            </div>
            <div>
              <dt>Agent</dt>
              <dd>Incident triage assistant</dd>
            </div>
            <div>
              <dt>Model</dt>
              <dd>Approved reasoning model</dd>
            </div>
            <div>
              <dt>Tool call</dt>
              <dd>query.case_records</dd>
            </div>
            <div>
              <dt>Policy verdict</dt>
              <dd><span class="verdict">Allowed</span> least-privilege scope</dd>
            </div>
            <div>
              <dt>Timestamp</dt>
              <dd>2026-04-27T17:18:42Z</dd>
            </div>
            <div>
              <dt>Audit trace ID</dt>
              <dd>lsig_evt_8F41C2A9</dd>
            </div>
          </dl>
        </aside>
      </div>
    </section>

    <section class="section" id="controls">
      <div class="container section-grid">
        <div class="section-heading">
          <p class="section-marker">What Runtime controls</p>
          <h2>Put every AI action behind a reviewable control point.</h2>
        </div>
        <div class="control-list">
          {controls.map(([title, body]) => (
            <article class="control-item">
              <h3>{title}</h3>
              <p>{body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section section-accent" id="products">
      <div class="container">
        <div class="section-intro">
          <p class="section-marker">Product family</p>
          <h2>Visibility, enforcement, and evidence on top of Runtime.</h2>
        </div>
        <div class="product-list">
          {products.map(([name, role, body]) => (
            <article class="product-item">
              <p class="product-label">{role}</p>
              <h3>{name}</h3>
              <p>{body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section architecture-section" id="architecture">
      <div class="container">
        <div class="section-intro architecture-intro">
          <p class="section-marker">Technical overview</p>
          <h2>Runtime sits between AI demand and enterprise systems.</h2>
        </div>
        <div class="architecture-strip" aria-label="Runtime architecture flow">
          <div>
            <span>Users / Agents</span>
            <p>Requests and delegated AI actions</p>
          </div>
          <span class="flow-arrow" aria-hidden="true">&rarr;</span>
          <div class="runtime-node">
            <span>LandmarkSignal Runtime</span>
            <p>Control, enforcement, trace</p>
          </div>
          <span class="flow-arrow" aria-hidden="true">&rarr;</span>
          <div>
            <span>Models / Tools / Data</span>
            <p>Approved execution targets</p>
          </div>
          <span class="flow-arrow" aria-hidden="true">&rarr;</span>
          <div>
            <span>SIEM / Audit Evidence</span>
            <p>Reviewable security record</p>
          </div>
        </div>
      </div>
    </section>

    <section class="section" id="threats">
      <div class="container section-grid">
        <div class="section-heading">
          <p class="section-marker">Threats addressed</p>
          <h2>Control the places where enterprise AI can break trust.</h2>
        </div>
        <ul class="threat-list">
          {threats.map((threat) => <li>{threat}</li>)}
        </ul>
      </div>
    </section>

    <section class="section section-accent" id="deployment">
      <div class="container">
        <div class="section-intro">
          <p class="section-marker">Deployment posture</p>
          <h2>Built for controlled enterprise environments.</h2>
        </div>
        <div class="deployment-grid">
          {deployment.map(([title, body]) => (
            <article class="deployment-item">
              <h3>{title}</h3>
              <p>{body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section cta-section" id="briefing">
      <div class="container cta-inner">
        <div>
          <p class="section-marker">Briefing</p>
          <h2>Evaluate Runtime for your AI control plane.</h2>
        </div>
        <div class="cta-copy">
          <p>
            Use a focused technical briefing to map where Runtime would sit across your
            models, agents, tools, data access paths, and evidence requirements.
          </p>
          <a
            class="button button-primary"
            href="mailto:briefings@landmarksignal.com?subject=LandmarkSignal%20Runtime%20Briefing"
          >
            Request a briefing
          </a>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>
