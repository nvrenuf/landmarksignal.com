---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";

const productLanes = [
  ["LandmarkSignal Radar", "Visibility / intelligence", "Radar sees AI activity and operational signals so security teams can understand what is happening across models, agents, and workflows."],
  ["LandmarkSignal Shield", "Enforcement / controls", "Shield controls policy, tool use, model routing, and data access so approved actions can proceed and risky actions can be constrained."],
  ["LandmarkSignal Audit", "Evidence / traceability", "Audit proves what happened with traceable evidence designed to support enterprise security, governance, and compliance reviews."]
];
---

<BaseLayout
  title="LandmarkSignal | Secure AI Operations"
  description="LandmarkSignal is a trusted intelligence platform company for secure AI operations. See every AI action, control every tool call, and prove every decision."
>
  <SiteHeader />

  <main id="top">
    <section class="hero">
      <div class="container hero-layout hero-layout-single">
        <div class="hero-copy">
          <p class="hero-kicker">Trusted intelligence platform company for secure AI operations</p>
          <h1>See every AI action. Control every tool call. Prove every decision.</h1>
          <p class="hero-body">
            Enterprises are adopting models, agents, tools, and AI workflows faster than security teams can
            see, control, and prove what happened. LandmarkSignal Runtime is the enterprise AI control plane
            designed to close that gap.
          </p>
          <div class="hero-actions">
            <a class="button button-primary" href="/runtime">Explore LandmarkSignal Runtime</a>
            <a
              class="button button-secondary"
              href="mailto:briefings@landmarksignal.com?subject=LandmarkSignal%20Platform%20Briefing"
            >
              Request a briefing
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="section section-accent" id="platform">
      <div class="container section-grid">
        <div class="section-heading">
          <p class="section-marker">Platform</p>
          <h2>LandmarkSignal Runtime is the enterprise AI control plane.</h2>
        </div>
        <div class="control-list">
          <article class="control-item">
            <h3>Company positioning</h3>
            <p>
              LandmarkSignal is a trusted intelligence platform company focused on secure AI operations for CISOs,
              CTOs, security architects, governance owners, and compliance stakeholders.
            </p>
          </article>
          <article class="control-item">
            <h3>What the platform does</h3>
            <p>
              Runtime sits between users, agents, models, tools, and enterprise data to provide visibility, policy
              enforcement, and traceable evidence.
            </p>
          </article>
        </div>
      </div>
    </section>

    <section class="section" id="products">
      <div class="container">
        <div class="section-intro">
          <p class="section-marker">Product family</p>
          <h2>Three product lanes on one control plane.</h2>
        </div>
        <div class="product-list">
          {productLanes.map(([name, label, body]) => (
            <article class="product-item">
              <p class="product-label">{label}</p>
              <h3>{name}</h3>
              <p>{body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section cta-section" id="next-step">
      <div class="container cta-inner">
        <div>
          <p class="section-marker">Next step</p>
          <h2>Go deeper on Runtime architecture, controls, and deployment patterns.</h2>
        </div>
        <div class="cta-copy">
          <p>
            Review how Runtime is designed to control model calls, mediate tool access, enforce policy decisions,
            and record representative audit traces across enterprise AI workflows.
          </p>
          <a class="button button-primary" href="/runtime">Go to /runtime</a>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>
