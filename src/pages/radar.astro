---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
---
<BaseLayout title="LandmarkSignal Radar" description="Signal intelligence for leaders who need to know what matters.">
  <SiteHeader />
  <main>
    <section class="hero product-hero">
      <div class="container hero-copy">
        <p class="hero-kicker">Early Product Page</p>
        <h1>Signal intelligence for leaders who need to know what matters.</h1>
        <p class="hero-body">Radar turns external signals, internal context, and evidence into decision-ready intelligence for executive, risk, security, and operations teams.</p>
        <p class="hero-body">This is an early product page and will be expanded with architecture, deployment patterns, and use cases.</p>
        <div class="hero-actions">
          <a class="button button-primary" href="/runtime">Explore Runtime</a>
          <a class="button button-secondary" href="mailto:briefings@landmarksignal.com?subject=LandmarkSignal%20Platform%20Briefing">Request a briefing</a>
        </div>
      </div>
    </section>
  </main>
  <SiteFooter />
</BaseLayout>
