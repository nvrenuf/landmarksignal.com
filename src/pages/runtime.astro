---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";

const heroBullets = [
  "Policy checks before agent action",
  "Controlled access to tools, data, and models",
  "Private/self-hosted deployment path",
  "Audit trails for security, compliance, and accountability"
];

const governedFlow = [
  "User",
  "Runtime",
  "Policy",
  "Permissions",
  "Approved tools/data/models",
  "Audited result"
];

const capabilities = [
  [
    "Agent identity",
    "Every agent has a defined role, purpose, permission scope, tenant context, and traceable identity."
  ],
  [
    "Policy enforcement",
    "Runtime checks actions before execution and fails closed when access is missing, unclear, or denied."
  ],
  [
    "Tool governance",
    "Browsers, APIs, databases, scanners, ticketing systems, cloud consoles, SIEMs, and code repositories sit behind controlled access."
  ],
  [
    "Model governance",
    "Runtime can route work to approved local, private, hosted, specialized, or smaller models based on sensitivity, task type, cost, and performance."
  ],
  [
    "Data access",
    "Documents, logs, evidence, vector stores, memory, and internal knowledge are accessed through governed boundaries."
  ],
  [
    "Audit trails",
    "Meaningful actions are recorded for security review, investigation, compliance, and accountability."
  ]
];

const audiences = [
  [
    "Cybersecurity and intelligence teams",
    "Investigate threats, enrich OSINT, correlate signals, review logs, and support analyst workflows without giving agents uncontrolled access to tools or evidence."
  ],
  [
    "Defense, public-sector, and mission-support organizations",
    "Run sensitive AI workflows in controlled environments where model use, tool access, data boundaries, and audit trails must be governed."
  ],
  [
    "MSSPs, MDR providers, and security consultancies",
    "Use AI across investigations, assessments, reporting, and monitoring while keeping each client's data, tools, and evidence separated."
  ],
  [
    "OSINT, investigative, and private intelligence teams",
    "Support due diligence, fraud research, executive-risk reviews, and digital investigations with repeatable, source-aware, auditable workflows."
  ],
  [
    "Critical infrastructure and operational security teams",
    "Assist with incident review, policy search, security documentation, and threat intelligence without allowing uncontrolled interaction with operational systems."
  ],
  [
    "Regulated and compliance-heavy organizations",
    "Adopt AI across sensitive workflows while preserving access control, evidence, model governance, and auditability."
  ]
];

const useCases = [
  "Cybersecurity investigation",
  "OSINT research",
  "SOC 2 and compliance evidence collection",
  "Vendor questionnaire review",
  "Business intelligence monitoring",
  "Developer/code-review support",
  "Customer-support automation",
  "Multi-agent research workflows"
];
---

<BaseLayout
  title="LandmarkSignal Runtime"
  description="LandmarkSignal Runtime is the governed execution layer for private enterprise AI."
>
  <SiteHeader />

  <main id="top">
    <section class="hero">
      <div class="container hero-layout">
        <div class="hero-copy">
          <p class="hero-kicker">LandmarkSignal Runtime</p>
          <h1>Run AI agents without losing control.</h1>
          <p class="hero-body">
            LandmarkSignal Runtime is a governed execution layer for private enterprise AI. It controls
            agent identity, policy enforcement, tool access, model routing, workflow execution, and audit
            trails across AI-powered operations.
          </p>
          <ul class="runtime-bullet-list" aria-label="Runtime key points">
            {heroBullets.map((item) => <li>{item}</li>)}
          </ul>
          <div class="hero-actions">
            <a
              class="button button-primary"
              href="mailto:briefings@landmarksignal.com?subject=LandmarkSignal%20Runtime%20Briefing"
            >
              Request a briefing
            </a>
            <a class="button button-secondary" href="/runtime/architecture">View technical architecture</a>
          </div>
        </div>

        <aside class="runtime-panel" aria-label="Representative runtime control panel">
          <div class="panel-topline">
            <div>
              <p>Governed execution snapshot</p>
              <span>Illustrative, non-live example</span>
            </div>
          </div>
          <dl class="event-details">
            <div>
              <dt>Request</dt>
              <dd>Review a vendor questionnaire and retrieve supporting evidence.</dd>
            </div>
            <div>
              <dt>Agent identity</dt>
              <dd>third_party_risk_assistant / tenant-finance / scoped role</dd>
            </div>
            <div>
              <dt>Policy verdict</dt>
              <dd><span class="verdict">Allowed</span> after tenant, purpose, and evidence rules matched</dd>
            </div>
            <div>
              <dt>Approved access</dt>
              <dd>knowledge base, ticketing API, approved enterprise model</dd>
            </div>
            <div>
              <dt>Workflow state</dt>
              <dd>retrieve, evaluate, draft response, record evidence</dd>
            </div>
            <div>
              <dt>Audit trail</dt>
              <dd>trace ID, inputs, policy decision, tool calls, result metadata</dd>
            </div>
          </dl>
        </aside>
      </div>
    </section>

    <section class="section" id="problem">
      <div class="container section-grid">
        <div class="section-heading">
          <p class="section-marker">Problem</p>
          <h2>Enterprise AI needs more than a model.</h2>
        </div>
        <div class="runtime-prose">
          <p>A model can answer questions. An agent can take action. That is where the risk begins.</p>
          <p>
            Once AI agents can touch documents, APIs, ticketing systems, databases, cloud tools, code
            repositories, logs, customer records, or compliance evidence, the question changes from “Can
            the AI do it?” to “Should it be allowed to do it?”
          </p>
          <p>LandmarkSignal Runtime answers that question before the action happens.</p>
        </div>
      </div>
    </section>

    <section class="section section-accent" id="governed-execution">
      <div class="container">
        <div class="section-intro">
          <p class="section-marker">Governed execution flow</p>
          <h2>From open-ended prompting to governed execution</h2>
        </div>
        <ol class="runtime-flow" aria-label="Governed execution flow">
          {governedFlow.map((step, index) => (
            <li>
              <span>{step}</span>
              {index < governedFlow.length - 1 && <i aria-hidden="true">&rarr;</i>}
            </li>
          ))}
        </ol>
        <p class="hero-body runtime-flow-copy">
          Runtime sits between users, agents, models, tools, and enterprise systems. Each meaningful
          action can be evaluated against identity, tenant, role, purpose, policy, data scope, model
          rules, and audit requirements before execution.
        </p>
      </div>
    </section>

    <section class="section" id="runtime-capabilities">
      <div class="container">
        <div class="section-intro">
          <p class="section-marker">Capabilities</p>
          <h2>What Runtime controls</h2>
        </div>
        <div class="product-list runtime-capabilities-grid">
          {capabilities.map(([title, body]) => (
            <article class="product-item runtime-capability-card">
              <h3>{title}</h3>
              <p>{body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section section-accent" id="runtime-audiences">
      <div class="container">
        <div class="section-intro">
          <p class="section-marker">Who Runtime is for</p>
          <h2>Built for teams that cannot afford uncontrolled AI</h2>
          <p class="runtime-section-copy">
            LandmarkSignal Runtime is designed for organizations where AI cannot operate as an unmanaged
            assistant. These teams need privacy, policy enforcement, controlled tool access, tenant
            separation, model governance, and defensible audit evidence before AI agents can interact
            with sensitive data or operational systems.
          </p>
        </div>
        <div class="runtime-audience-grid">
          {audiences.map(([title, body]) => (
            <article class="runtime-audience-card">
              <h3>{title}</h3>
              <p>{body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section section-accent" id="runtime-use-cases">
      <div class="container section-grid">
        <div class="section-heading">
          <p class="section-marker">Use cases</p>
          <h2>Built for real enterprise workflows</h2>
        </div>
        <div class="runtime-use-case-content">
          <p>
            Runtime is designed for AI systems that do more than chat. It supports governed workflows
            where agents retrieve evidence, call tools, analyze records, produce recommendations, and
            leave a defensible trail.
          </p>
          <ul class="threat-list">
            {useCases.map((item) => <li>{item}</li>)}
          </ul>
        </div>
      </div>
    </section>

    <section class="section" id="runtime-not">
      <div class="container section-grid">
        <div class="section-heading">
          <p class="section-marker">Positioning</p>
          <h2>Not a chatbot. Not a model wrapper.</h2>
        </div>
        <div class="runtime-prose">
          <p>
            LandmarkSignal Runtime is not a chatbot, a single AI model, an Ollama dashboard, an
            OpenWebUI replacement, or a thin wrapper around hosted AI.
          </p>
          <p>Those systems may connect to it.</p>
          <p>
            Runtime is the governed operating layer beneath AI-powered applications — the part that
            controls identity, policy, permissions, tools, models, workflows, logs, and evidence.
          </p>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>
