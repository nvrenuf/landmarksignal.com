---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
---
<BaseLayout title="LandmarkSignal Shield" description="Policy enforcement and risk controls for enterprise AI.">
  <SiteHeader />
  <main>
    <section class="hero product-hero">
      <div class="container hero-copy">
        <p class="hero-kicker">Early Product Page</p>
        <h1>Policy enforcement and risk controls for enterprise AI.</h1>
        <p class="hero-body">Shield helps organizations constrain risky AI actions, protect sensitive data paths, and enforce governance across models, tools, agents, and users.</p>
        <p class="hero-body">This is an early product page and will be expanded with control patterns, policy templates, and operating guidance.</p>
        <div class="hero-actions">
          <a class="button button-primary" href="/runtime">Explore Runtime</a>
          <a class="button button-secondary" href="mailto:briefings@landmarksignal.com?subject=LandmarkSignal%20Platform%20Briefing">Request a briefing</a>
        </div>
      </div>
    </section>
  </main>
  <SiteFooter />
</BaseLayout>
