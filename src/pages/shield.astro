---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
---
<BaseLayout title="LandmarkSignal Shield" description="Enforcement and controls for AI actions.">
  <SiteHeader />
  <main>
    <section class="hero"><div class="container hero-layout"><div class="hero-copy"><p class="hero-kicker">LandmarkSignal Shield</p><h1>Enforcement and controls for AI actions.</h1><p class="hero-body">Shield enforces policy decisions before AI actions execute, helping teams control access, constrain risk, and apply clear operating boundaries across models, agents, and tools.</p><div class="hero-actions"><a class="button button-primary" href="mailto:briefings@landmarksignal.com?subject=LandmarkSignal%20Shield%20Briefing">Request a Briefing</a></div></div><aside class="runtime-panel"><div class="panel-topline"><div><p>Policy verdict panel</p><span>Illustrative, non-live example</span></div></div><dl class="event-details"><div><dt>Requested action</dt><dd>Agent asked to export customer records to external destination.</dd></div><div><dt>Policy verdict</dt><dd><span class="verdict denied">Denied</span> destination not approved for tenant role.</dd></div><div><dt>Enforced controls</dt><dd>Model route restriction, tool denial, alert escalation</dd></div><div><dt>Recorded context</dt><dd>Actor identity, policy version, decision reason</dd></div></dl></aside></div></section>
    <section class="section section-accent"><div class="container section-grid"><div class="section-heading"><p class="section-marker">Control scope</p><h2>What Shield controls</h2></div><div class="runtime-use-case-content"><ul class="threat-list"><li>Policy decisions across users, agents, and workflow types</li><li>Access gateways for tools, APIs, data stores, and model endpoints</li><li>Model routing constraints by sensitivity, cost, and purpose</li><li>Data guard conditions for outbound actions and restricted content</li></ul></div></div></section>
    <section class="section"><div class="container"><div class="section-intro"><p class="section-marker">Architecture position</p><h2>Where Shield sits in the AI stack</h2></div><div class="architecture-strip"><div><span>Intent</span><p>User and agent requests enter controlled runtime</p></div><i>→</i><div><span>Shield policy layer</span><p>Identity checks, purpose checks, and access evaluation</p></div><i>→</i><div><span>Allowed pathways</span><p>Approved models, tools, and bounded data scopes</p></div><i>→</i><div><span>Audited output</span><p>Decision results with enforcement context</p></div></div></div></section>
    <section class="section section-accent"><div class="container"><div class="section-intro"><p class="section-marker">Core components</p><h2>Enforcement components</h2></div><div class="product-list"><article class="product-item"><h3>Policy engine</h3><p>Evaluates runtime requests against tenant policies and explicit trust boundaries.</p></article><article class="product-item"><h3>Access gateway</h3><p>Controls which tools, systems, and data endpoints can be reached by each actor.</p></article><article class="product-item"><h3>Model router</h3><p>Routes tasks to approved model classes according to risk and operational policy.</p></article><article class="product-item"><h3>Data guard</h3><p>Applies protective checks before outbound data movement or high-risk actions.</p></article></div></div></section>
    <section class="section"><div class="container section-grid"><div class="section-heading"><p class="section-marker">Threats addressed</p><h2>Prevent uncontrolled AI action paths</h2></div><div class="runtime-use-case-content"><ul class="threat-list"><li>Unauthorized access to sensitive systems and data</li><li>Prompt injection leading to unsafe tool actions</li><li>Unapproved model usage in high-trust workflows</li><li>Data exfiltration through poorly controlled integrations</li></ul></div></div></section>
    <section class="section section-accent"><div class="container section-grid"><div class="section-heading"><p class="section-marker">Deployment patterns</p><h2>Designed to support controlled deployment options</h2></div><div class="runtime-prose"><p>Shield is designed to support local/self-hosted, private cloud, and hybrid deployment patterns aligned to enterprise security requirements.</p><p>Specific deployment combinations and advanced policy packages may follow roadmap sequencing by environment.</p></div></div></section>
    <section class="section"><div class="container section-grid"><div class="section-heading"><p class="section-marker">What it is not</p><h2>Shield is not full IAM or enterprise DLP</h2></div><div class="runtime-prose"><p>Shield focuses on enforcement and control for AI runtime actions.</p><p>It is not positioned as a complete standalone IAM suite or a full enterprise data-loss prevention platform.</p></div></div></section>
  </main>
  <SiteFooter />
</BaseLayout>
